# Copy this file to ".env" and fill in your values, then restart the server.
# (.env is git-ignored — never commit real secrets.)

# ── Security ──
# A long random string used to sign login tokens. Change this in production!
JWT_SECRET=change-me-to-a-long-random-string

# First admin account (production — set a strong password before go-live)
# ADMIN_SEED_EMAIL=admin@peoplesbakers.lk
# ADMIN_SEED_PASSWORD=your-strong-admin-password-here

# Public URL of your site (used in email links). e.g. https://peoplesbakers.lk
SITE_URL=http://localhost:3000

# ── Email (SMTP) ──
# Leave these blank to disable emails (the app still works, just no emails sent).
#
# Easiest option — Gmail:
#   1. Turn on 2-Step Verification on your Google account.
#   2. Create an "App password": https://myaccount.google.com/apppasswords
#   3. Use the 16-character app password below as SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your-16-char-app-password
MAIL_FROM="Peoples Bakers <youraddress@gmail.com>"

# ── Google Sign-In (optional) ──
# Lets users log in with their Gmail/Google account.
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Create "OAuth client ID" -> Application type: Web application
#   3. Authorized JavaScript origins: http://localhost:3000 (and your live domain)
#   4. Copy the Client ID below (it ends with .apps.googleusercontent.com)
# Leave blank to disable Google sign-in (email/password still works).
GOOGLE_CLIENT_ID=

# ── Google Maps / Places (optional) ──
# Auto-import extra Peoples Bakers listings from Google into /api/outlets.
# 1. Google Cloud → enable "Places API"
# 2. Create an API key and restrict it to your domain/server
# 3. Add below and restart the server
# GOOGLE_MAPS_API_KEY=
#
# Docs: GET http://localhost:3000/api/outlets/docs

# ── Database (optional) ──
# Custom path for the SQLite file (useful on hosts with a mounted disk).
# DB_PATH=/data/peoples-bakers.db

# ── PayHere (online payments) ──
# Sign up: https://www.payhere.lk/  · Sandbox: https://sandbox.payhere.lk/
# Merchant ID & Secret from PayHere dashboard → Integrations.
# Use sandbox keys while testing (PAYHERE_SANDBOX=true).
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_SANDBOX=true
PAYHERE_CURRENCY=LKR
# Notify URL must be public HTTPS in production (PayHere calls /api/payments/payhere/notify).

# ── Admin access (optional) ──
# Secret staff URL — NOT linked from the public website. Customers get 404 if they find it.
# Default: pb-office.html  (change to something only your team knows)
ADMIN_PATH=pb-office.html
# Promote an existing site user to admin on server start (they must register first).
# ADMIN_PROMOTE_EMAIL=you@gmail.com
# Or run once: npm run promote-admin -- you@gmail.com

# ── Phone discount (checkout) ──
# Valid Sri Lankan mobile (07XXXXXXXX) gets automatic discount at checkout.
PHONE_DISCOUNT_PERCENT=20
PHONE_DISCOUNT_MIN=500
